<Page
    x:Class="AnimeStreamer.Views.FolderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:StreamApp.ViewModels"
    Background="#0F0F0F">

    <Grid Background="#0F0F0F" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Content="Back" Click="BackButton_Click" Style="{StaticResource Action}" Margin="0,0,0,20"/>

        <TextBlock x:Name="AnimeTitleText" Text="Anime Title" FontSize="32" FontWeight="Bold" Foreground="White" Grid.Row="1" Margin="0,0,0,20"/>

        <ProgressRing x:Name="EpisodesLoadingRing" IsActive="False" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E50914"/>

        <ListView x:Name="EpisodesList" Grid.Row="2" SelectionMode="Single" ItemClick="EpisodesList_ItemClick" IsItemClickEnabled="True">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12" BorderBrush="#333333" BorderThickness="0,0,0,1">
                        <TextBlock Text="{Binding Title}" Foreground="White" FontSize="16" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
