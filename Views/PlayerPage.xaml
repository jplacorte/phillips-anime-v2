<Page
    x:Class="AnimeStreamer.Views.PlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vlc="using:LibVLCSharp.Platforms.Windows"
    Background="Black">

    <Grid>
        <vlc:VideoView x:Name="VideoView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <ProgressRing x:Name="BufferingRing" IsActive="True" Foreground="#E50914" Width="60" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>

        <Button Content="Back" Click="BackButton_Click" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="24" Background="#80000000" Foreground="White" Style="{StaticResource Action}"/>
    </Grid>
</Page>