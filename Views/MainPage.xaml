<Page
    x:Class="AnimeStreamer.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:StreamApp.ViewModels"
    Background="#0F0F0F">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="My Anime Library" FontSize="32" FontWeight="Bold" Foreground="White" Margin="24,24,0,24"/>

        <!-- Container for the collection and overlays -->
        <Grid Grid.Row="1">
            <GridView x:Name="AnimeGrid"
                      IsItemClickEnabled="True"
                      SelectionMode="None"
                      ItemClick="AnimeGrid_ItemClick"
                      Margin="24">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="local:AnimeItemViewModel">
                        <Border Width="200" Height="300" Margin="10" CornerRadius="8" Background="Transparent">
                            <Grid>
                                <Image Source="{x:Bind CoverUrl, Mode=OneWay}" Stretch="UniformToFill" />

                                <Border VerticalAlignment="Bottom" Height="100">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#00000000" Offset="0.0"/>
                                            <GradientStop Color="#E6000000" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <TextBlock Text="{x:Bind Title}"
                                           Foreground="White" FontWeight="SemiBold"
                                           VerticalAlignment="Bottom" Margin="10"
                                           TextWrapping="WrapWholeWords" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- Start inactive so the grid is clickable immediately. Also make overlays non-hit-testable so they don't block clicks. -->
            <ProgressRing x:Name="LoadingRing" IsActive="False" Width="50" Height="50" Foreground="#E50914" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>

            <TextBlock x:Name="ErrorText" Foreground="#E50914" FontSize="16" TextWrapping="Wrap" Margin="24" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
        </Grid>
    </Grid>
</Page>